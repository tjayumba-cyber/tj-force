# Google Calendar Appointment Schedule booking page URL
# Create one at: https://calendar.google.com → Create → Appointment schedule
# Example: https://calendar.app.google/4TGesWEu6YF6Hsqh8
VITE_GOOGLE_CALENDAR_BOOKING_URL=

# Optional: calendar embed for month/week view (view-only)
# Example: https://calendar.google.com/calendar/embed?src=you%40gmail.com&ctz=America%2FChicago
VITE_GOOGLE_CALENDAR_EMBED_URL=
